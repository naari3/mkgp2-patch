# Build artifacts (generated by build.sh)
*.o
*.bin
!features/*/files/*.bin
generated_joints.h
generated_cup_courses.h
generated_custom_assets.h
generated_riivolution.xml
mkgp2_patch.xml
mkgp2_patch_gecko.txt
mkgp2_patch_riiv_raw.xml
mkgp2_patch.map
# patch_map.md is generated but committed so diffs show hook changes in PRs

# Generated by gen_mod_yaml.py
mod_joints.yaml

# Local tooling config (user-specific absolute paths)
.mcp.json

# FST dump is derived from the user's local ISO extract; regenerate with
# tools/fst_lookup.py (reads sys/fst.bin from the Dolphin extract dir).
tools/fst_dump.txt
tools/tpl_index.txt
tools/tpl_png/
tools/*.decompressed.bin
tools/resource_table.txt
tools/__pycache__/
tools/**/__pycache__/

# User-local game extraction / dump artifacts (= Dolphin filesystem dump,
# extracted texture caches). Sometimes file, sometimes dir depending on
# how Dolphin Extract was invoked, so no trailing slash. Regenerate with
# the Dolphin "Extract files" action; not shared between machines.
/Extract
/Filesystem
/tex

# Per-project Claude Code settings. Records user-specific tool permissions
# and per-conversation tweaks; not shared.
.claude/settings.local.json

# One-shot debug scripts kept locally during investigations. Reusable
# dump / compare helpers (hsd_compare_*, hsd_dump_*) live alongside
# without the underscore prefix and ARE tracked.
tools/_inspect_*.py
tools/_swap_*.py
tools/hsd/check_*.csx
tools/hsd/compare_*.csx
tools/hsd/dump_*.csx
